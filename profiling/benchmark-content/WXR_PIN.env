# Pinned SHA for the upstream theme-test-data WXR fixture.
# Bump this (and re-run the seed) to pick up new block-test data from WP core.
#
# Repo: https://github.com/WordPress/theme-test-data
# File: themeunittestdata.wordpress.xml (the modern block-aware fixture;
#       upstream stopped shipping 64-block-test-data.xml as a separate file
#       and now merges block coverage into the main WXR).
WXR_REPO=WordPress/theme-test-data
WXR_REF=master
WXR_FILE=themeunittestdata.wordpress.xml
